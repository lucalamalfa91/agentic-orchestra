# Adesso AI Hub API Configuration
ADESSO_AI_HUB_KEY=your-api-key-here
ADESSO_BASE_URL=https://adesso-ai-hub.3asabc.de/v1

# GitHub Repository Configuration
REPO_NAME=app-generated

# GitHub Authentication (for publishing generated apps)
GITHUB_TOKEN=your-github-personal-access-token

# Optional: GitHub Organization (leave empty to use personal account)
GITHUB_ORG=

# Optional: Database path (defaults to database/orchestrator.db)
DATABASE_URL=sqlite:///database/orchestrator.db

# Security: JWT Secret for authentication (change in production)
JWT_SECRET=your-random-secret-key-here-change-in-production

# NOTE: ENCRYPTION_KEY is auto-generated and stored in database/encryption.key (not in .env)

# OAuth: GitHub OAuth App credentials (for user authentication)
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback

# OAuth: Vercel integration (optional)
VERCEL_CLIENT_ID=your-vercel-client-id
VERCEL_CLIENT_SECRET=your-vercel-client-secret
VERCEL_REDIRECT_URI=http://localhost:5173/auth/callback

# OAuth: Railway integration (optional)
RAILWAY_CLIENT_ID=your-railway-client-id
RAILWAY_CLIENT_SECRET=your-railway-client-secret
RAILWAY_REDIRECT_URI=http://localhost:5173/auth/callback
