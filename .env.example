# Database
DATABASE_URL=sqlite:///./test.db

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5173/auth/callback

# Vercel OAuth
VERCEL_CLIENT_ID=your_vercel_client_id
VERCEL_CLIENT_SECRET=your_vercel_client_secret

# Railway OAuth
RAILWAY_CLIENT_ID=your_railway_client_id
RAILWAY_CLIENT_SECRET=your_railway_client_secret

# JWT Secret
JWT_SECRET=your_secret_key_here

# Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_encryption_key_here

# AI Provider (OLD - still supported)
ADESSO_BASE_URL=https://api.openai.com/v1
ADESSO_AI_HUB_KEY=your_api_key

# AI Provider (NEW)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_api_key
